{
  "comments": {
    "lineComment": ";"
  },
  "brackets": [
    ["(", ")"],
    ["[", "]"]
  ],
  "autoClosingPairs": [
    { "open": "(", "close": ")" },
    { "open": "[", "close": "]" },
    { "open": "\"", "close": "\"", "notIn": ["string"] }
  ],
  "surroundingPairs": [
    ["(", ")"],
    ["[", "]"],
    ["\"", "\""]
  ],
  "indentationRules": {
    "increaseIndentPattern": "^\\s*[(\\[](?!.*[)\\]]\\s*$).*$",
    "decreaseIndentPattern": "^\\s*[)\\]]\\s*$"
  },
  "onEnterRules": [
    {
      "beforeText": "^\\s*[(\\[]\\s*$",
      "action": { "indent": "indent" }
    },
    {
      "beforeText": "[)\\]]\\s*$",
      "action": { "indent": "none" }
    }
  ],
  "wordPattern": "[^\\s()\\[\\];\"'`,#]+"
}
