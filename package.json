{
  "name": "anchor-lang",
  "displayName": "Anchor Language",
  "description": "Syntax highlighting and auto-indent for the Anchor programming language",
  "version": "0.2.0",
  "engines": {
    "vscode": "^1.75.0"
  },
  "categories": ["Programming Languages"],
  "activationEvents": [
    "onLanguage:anchor"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "languages": [
      {
        "id": "anchor",
        "aliases": ["Anchor", "anchor"],
        "extensions": [".anc"],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "anchor",
        "scopeName": "source.anchor",
        "path": "./syntaxes/anchor.tmLanguage.json"
      }
    ],
    "configurationDefaults": {
      "[anchor]": {
        "editor.formatOnType": true
      }
    }
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./"
  },
  "devDependencies": {
    "@types/vscode": "^1.75.0",
    "typescript": "^5.0.0"
  }
}
